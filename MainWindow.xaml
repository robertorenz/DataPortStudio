<Window x:Class="DataPortStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:DataPortStudio.Converters"
        xmlns:beh="clr-namespace:DataPortStudio.Behaviors"
        xmlns:vm="clr-namespace:DataPortStudio.ViewModels"
        xmlns:v="clr-namespace:DataPortStudio.Views"
        xmlns:loc="clr-namespace:DataPortStudio.Services"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="DataPortStudio — SQL Server Manager" Height="720" Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource B.Bg}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding AddConnectionCommand}"/>
        <KeyBinding Modifiers="Control" Key="Q" Command="{Binding OpenQueryCommand}"/>
        <KeyBinding Modifiers="Control" Key="B" Command="{Binding OpenQueryBuilderCommand}"/>
        <KeyBinding Key="F5" Command="{Binding RefreshNodeCommand}"/>
        <KeyBinding Key="F1" Command="{Binding OpenDocsCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <conv:NodeTypeToGeometryConverter x:Key="Geo"/>
        <conv:NodeTypeToBrushConverter x:Key="NodeBrush"/>
        <conv:NodeIconConverter x:Key="NodeIcon"/>
        <conv:NodeIconBrushConverter x:Key="NodeIconBrush"/>

        <!-- Command-bar icon gradients (diagonal, with a highlight) -->
        <LinearGradientBrush x:Key="GBlue" StartPoint="0.1,0" EndPoint="0.9,1">
            <GradientStop Color="#73B7F8" Offset="0"/><GradientStop Color="#3D8AE6" Offset="0.5"/><GradientStop Color="#2167C4" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GGreen" StartPoint="0.1,0" EndPoint="0.9,1">
            <GradientStop Color="#6BD297" Offset="0"/><GradientStop Color="#3DAE69" Offset="0.5"/><GradientStop Color="#23864B" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GTeal" StartPoint="0.1,0" EndPoint="0.9,1">
            <GradientStop Color="#41D2BA" Offset="0"/><GradientStop Color="#1FAE99" Offset="0.5"/><GradientStop Color="#0E7F70" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GPurple" StartPoint="0.1,0" EndPoint="0.9,1">
            <GradientStop Color="#BC81DF" Offset="0"/><GradientStop Color="#9A52B8" Offset="0.5"/><GradientStop Color="#7C399A" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="GAmber" StartPoint="0.1,0" EndPoint="0.9,1">
            <GradientStop Color="#F6C56B" Offset="0"/><GradientStop Color="#E8943A" Offset="0.5"/><GradientStop Color="#C9701C" Offset="1"/>
        </LinearGradientBrush>
        <conv:IsNullToVisibilityConverter x:Key="NullToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <HierarchicalDataTemplate DataType="{x:Type vm:DbTreeNode}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" Margin="2,3">
                <Path Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0"
                      Data="{Binding Converter={StaticResource NodeIcon}}"
                      Stroke="{Binding Converter={StaticResource NodeIconBrush}}"
                      StrokeThickness="1.3" Fill="Transparent" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                <TextBlock Text="loading…" Margin="8,0,0,0" FontSize="11" FontStyle="Italic"
                           Foreground="{StaticResource B.SidebarMuted}" VerticalAlignment="Center"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===================== COMMAND BAR ===================== -->
        <Border Grid.Row="1" Background="{StaticResource B.SurfaceAlt}"
                BorderBrush="{StaticResource B.Border}" BorderThickness="0,0,0,1" Padding="10,4">
            <StackPanel Orientation="Horizontal">
                <!-- Connection (glossy green plug) -->
                <Button Style="{StaticResource RibbonButton}" Command="{Binding AddConnectionCommand}">
                    <StackPanel>
                        <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                            <Path Fill="{StaticResource GGreen}" Data="M8.3,3.2 H9.9 A0.3,0.3 0 0 1 10.2,3.5 V7.3 H8 V3.5 A0.3,0.3 0 0 1 8.3,3.2 Z"/>
                            <Path Fill="{StaticResource GGreen}" Data="M14.1,3.2 H15.7 A0.3,0.3 0 0 1 16,3.5 V7.3 H13.8 V3.5 A0.3,0.3 0 0 1 14.1,3.2 Z"/>
                            <Path Fill="{StaticResource GGreen}" Data="M5.8,7 H18.2 V10 A6.2,6.2 0 0 1 5.8,10 Z"/>
                            <Path Fill="#40FFFFFF" Data="M7,7.5 H17 A0.6,0.6 0 0 1 17,8.7 H7 A0.6,0.6 0 0 1 7,7.5 Z"/>
                            <Path Fill="{StaticResource GGreen}" Data="M11.1,15 H12.9 V19 H11.1 Z"/>
                            <Path Fill="#86CCA1" Data="M7.5,18 H16.5 A1.6,1.6 0 0 1 18.1,19.6 V21 H5.9 V19.6 A1.6,1.6 0 0 1 7.5,18 Z"/>
                        </Canvas>
                        <TextBlock Text="{loc:Tr Bar_Connection}" FontSize="11" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
                <!-- New Query (document + green plus) -->
                <Button Style="{StaticResource RibbonButton}" Command="{Binding OpenQueryCommand}">
                    <StackPanel>
                        <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                            <Path Fill="#F4F9FE" Stroke="#9CC0EA" StrokeThickness="0.9"
                                  Data="M5,2.5 H12.7 L17.5,7.3 V20.3 A0.7,0.7 0 0 1 16.8,21 H5.7 A0.7,0.7 0 0 1 5,20.3 Z"/>
                            <Path Fill="{StaticResource GBlue}" Data="M12.7,2.5 V6.6 A0.7,0.7 0 0 0 13.4,7.3 H17.5 Z"/>
                            <Path Stroke="#A7B5C3" StrokeThickness="1.1" StrokeStartLineCap="Round"
                                  Data="M7.5,11 H12.8 M7.5,13.2 H12.8 M7.5,15.4 H10.6"/>
                            <Path Fill="{StaticResource GGreen}" Data="M17,13.5 m-4.6,0 a4.6,4.6 0 1,0 9.2,0 a4.6,4.6 0 1,0 -9.2,0 Z"/>
                            <Path Fill="White" Data="M16.2,16 H17.8 V14.4 H19.4 V12.8 H17.8 V11.2 H16.2 V12.8 H14.6 V14.4 H16.2 Z"/>
                        </Canvas>
                        <TextBlock Text="{loc:Tr Bar_NewQuery}" FontSize="11" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
                <!-- Visual Designer (linked tiles) -->
                <Button Style="{StaticResource RibbonButton}" Command="{Binding OpenQueryBuilderCommand}">
                    <StackPanel>
                        <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                            <Path Stroke="#B7C2CE" StrokeThickness="1.6" Fill="Transparent"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M10.9,6.7 H12.6 V15.8 H14.1"/>
                            <Path Fill="{StaticResource GBlue}" Data="M2.5,3.3 H9.7 A1.3,1.3 0 0 1 11,4.6 V8.4 A1.3,1.3 0 0 1 9.7,9.7 H2.5 A1.3,1.3 0 0 1 1.2,8.4 V4.6 A1.3,1.3 0 0 1 2.5,3.3 Z"/>
                            <Path Stroke="#B3FFFFFF" StrokeThickness="0.9" Data="M3.1,5.5 H9 M3.1,7.2 H7"/>
                            <Path Fill="{StaticResource GTeal}" Data="M14.3,12.9 H21.5 A1.3,1.3 0 0 1 22.8,14.2 V18 A1.3,1.3 0 0 1 21.5,19.3 H14.3 A1.3,1.3 0 0 1 13,18 V14.2 A1.3,1.3 0 0 1 14.3,12.9 Z"/>
                            <Path Stroke="#B3FFFFFF" StrokeThickness="0.9" Data="M14.9,15.1 H20.8 M14.9,16.8 H18.8"/>
                        </Canvas>
                        <TextBlock Text="{loc:Tr Bar_VisualDesigner}" FontSize="11" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
                <Border Width="1" Background="{StaticResource B.Border}" Margin="6,4"/>
                <!-- Table (rounded card, blue header) -->
                <Button Style="{StaticResource RibbonButton}" Command="{Binding GoToTablesCommand}">
                    <StackPanel>
                        <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                            <Path Fill="#FFFFFF" Data="M4,4 H20 A2,2 0 0 1 22,6 V18 A2,2 0 0 1 20,20 H4 A2,2 0 0 1 2,18 V6 A2,2 0 0 1 4,4 Z"/>
                            <Path Fill="{StaticResource GBlue}" Data="M4,4 H20 A2,2 0 0 1 22,6 V8.6 H2 V6 A2,2 0 0 1 4,4 Z"/>
                            <Path Stroke="#C3D4E6" StrokeThickness="0.9" Data="M8.7,8.6 V20 M15.3,8.6 V20 M2,12.7 H22 M2,16.4 H22"/>
                            <Path Stroke="#2D7FE0" StrokeThickness="1.1" Fill="Transparent" Data="M4,4 H20 A2,2 0 0 1 22,6 V18 A2,2 0 0 1 20,20 H4 A2,2 0 0 1 2,18 V6 A2,2 0 0 1 4,4 Z"/>
                        </Canvas>
                        <TextBlock Text="{loc:Tr Bar_Table}" FontSize="11" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
                <!-- View (teal eye with glint) -->
                <Button Style="{StaticResource RibbonButton}" Command="{Binding GoToViewsCommand}">
                    <StackPanel>
                        <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                            <Path Fill="{StaticResource GTeal}" Data="M2,12 C5,6 19,6 22,12 C19,18 5,18 2,12 Z"/>
                            <Path Fill="White" Data="M12,8.4 a3.6,3.6 0 1,0 0.01,0 Z"/>
                            <Path Fill="#147567" Data="M12,9.9 a2.1,2.1 0 1,0 0.01,0 Z"/>
                            <Path Fill="White" Data="M13,9.4 a0.7,0.7 0 1,0 0.01,0 Z"/>
                        </Canvas>
                        <TextBlock Text="{loc:Tr Bar_View}" FontSize="11" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
                <!-- Function (purple ƒx tile) -->
                <Button Style="{StaticResource RibbonButton}" Command="{Binding GoToFunctionsCommand}">
                    <StackPanel>
                        <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                            <Path Fill="{StaticResource GPurple}" Data="M4.5,3.5 H19.5 A2.5,2.5 0 0 1 22,6 V18 A2.5,2.5 0 0 1 19.5,20.5 H4.5 A2.5,2.5 0 0 1 2,18 V6 A2.5,2.5 0 0 1 4.5,3.5 Z"/>
                            <Path Fill="#28FFFFFF" Data="M4.5,3.5 H19.5 A2.5,2.5 0 0 1 22,6 V9 H2 V6 A2.5,2.5 0 0 1 4.5,3.5 Z"/>
                            <TextBlock Canvas.Left="0" Canvas.Top="2.5" Width="24" TextAlignment="Center"
                                       Text="ƒx" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                        </Canvas>
                        <TextBlock Text="{loc:Tr Bar_Function}" FontSize="11" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
                <!-- Stored Procedure (teal SP tile) -->
                <Button Style="{StaticResource RibbonButton}" Command="{Binding GoToProceduresCommand}">
                    <StackPanel>
                        <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                            <Path Fill="{StaticResource GTeal}" Data="M4.5,3.5 H19.5 A2.5,2.5 0 0 1 22,6 V18 A2.5,2.5 0 0 1 19.5,20.5 H4.5 A2.5,2.5 0 0 1 2,18 V6 A2.5,2.5 0 0 1 4.5,3.5 Z"/>
                            <Path Fill="#28FFFFFF" Data="M4.5,3.5 H19.5 A2.5,2.5 0 0 1 22,6 V9 H2 V6 A2.5,2.5 0 0 1 4.5,3.5 Z"/>
                            <TextBlock Canvas.Left="0" Canvas.Top="2.5" Width="24" TextAlignment="Center"
                                       Text="SP" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                        </Canvas>
                        <TextBlock Text="{loc:Tr Bar_Procedure}" FontSize="11" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
                <Border Width="1" Background="{StaticResource B.Border}" Margin="6,4"/>
                <!-- Schema Diff -->
                <Button Style="{StaticResource RibbonButton}" Command="{Binding OpenSchemaDiffCommand}">
                    <StackPanel>
                        <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                            <Path Fill="#5C6BC0" Data="M2,4 H10 V10 H2 Z M14,4 H22 V10 H14 Z"/>
                            <Path Stroke="#9E9E9E" StrokeThickness="1.4" Fill="Transparent"
                                  Data="M10,7 H14 M12,5.5 L14,7 L12,8.5"/>
                            <Path Stroke="#5C6BC0" StrokeThickness="1" Fill="Transparent"
                                  Data="M3,12 H21 M3,15 H18 M3,18 H14"/>
                        </Canvas>
                        <TextBlock Text="Diff" FontSize="11" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
                <!-- ER Diagram -->
                <Button Style="{StaticResource RibbonButton}" Command="{Binding OpenErDiagramCommand}">
                    <StackPanel>
                        <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                            <Ellipse Canvas.Left="1"  Canvas.Top="9"  Width="7" Height="7" Fill="#26C6DA"/>
                            <Ellipse Canvas.Left="16" Canvas.Top="2"  Width="7" Height="7" Fill="#4DB6AC"/>
                            <Ellipse Canvas.Left="16" Canvas.Top="16" Width="7" Height="7" Fill="#4DB6AC"/>
                            <Path Stroke="#90A4AE" StrokeThickness="1.2" Fill="Transparent"
                                  Data="M8,12.5 L16,5.5 M8,12.5 L16,19.5"/>
                        </Canvas>
                        <TextBlock Text="ER" FontSize="11" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
                <Border Width="1" Background="{StaticResource B.Border}" Margin="6,4"/>
                <!-- Users & Roles (amber person, dropdown) -->
                <Button Style="{StaticResource RibbonButton}" Click="UsersButton_Click">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{loc:Tr Bar_ManageUsers}"
                                      Command="{Binding PlacementTarget.DataContext.OpenUserManagerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <Separator/>
                            <MenuItem Header="{loc:Tr Bar_NewUser}"
                                      Command="{Binding PlacementTarget.DataContext.NewUserShortcutCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Header="{loc:Tr Bar_NewRole}"
                                      Command="{Binding PlacementTarget.DataContext.NewRoleShortcutCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <StackPanel>
                        <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                            <Path Fill="{StaticResource GAmber}" Data="M12,4.2 A3.4,3.4 0 1 1 11.99,4.2 Z"/>
                            <Path Fill="#40FFFFFF" Data="M10.6,5.2 A1.2,1.2 0 1 1 10.59,5.2 Z"/>
                            <Path Fill="{StaticResource GAmber}" Data="M5.2,20 C5.2,14.8 18.8,14.8 18.8,20 A0.6,0.6 0 0 1 18.2,20.6 H5.8 A0.6,0.6 0 0 1 5.2,20 Z"/>
                            <Path Fill="#33FFFFFF" Data="M7.4,16.6 C9.8,15.1 14.2,15.1 16.6,16.6 C14.2,15.6 9.8,15.6 7.4,16.6 Z"/>
                            <Path Stroke="#7A5320" StrokeThickness="0.7" Fill="Transparent"
                                  Data="M19.2,18.5 L21.4,18.5 M20.3,17.4 L20.3,19.6"/>
                        </Canvas>
                        <TextBlock Text="{loc:Tr Bar_Users}" FontSize="11" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
                <Border Width="1" Background="{StaticResource B.Border}" Margin="6,4"/>
                <!-- Refresh (green circular arrow) -->
                <Button Style="{StaticResource RibbonButton}" Command="{Binding RefreshNodeCommand}">
                    <StackPanel>
                        <Canvas Width="24" Height="24" HorizontalAlignment="Center">
                            <Path Stroke="{StaticResource GGreen}" StrokeThickness="2.4" Fill="Transparent"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M19,9.2 A7,7 0 1 0 19.6,14.3"/>
                            <Path Fill="{StaticResource GGreen}" Data="M14.6,3.6 L20.6,8.4 L13.8,10 Z"/>
                        </Canvas>
                        <TextBlock Text="{loc:Tr Bar_Refresh}" FontSize="11" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- ===================== TOP BAR ===================== -->
        <Border Grid.Row="0" Background="{StaticResource B.HeaderBar}"
                BorderBrush="{StaticResource B.Border}" BorderThickness="0,0,0,1" Padding="18,12">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="26" Height="26" CornerRadius="6" Background="{StaticResource B.Sidebar}">
                        <Path Data="M2,3 H14 V6.5 H2 Z M2,9.5 H14 V13 H2 Z" Width="15" Height="15"
                              Stretch="Uniform" Stroke="#FF2D7FE0" StrokeThickness="1.4"/>
                    </Border>
                    <TextBlock Text="DataPortStudio" FontSize="16" FontWeight="Bold" Margin="10,0,0,0"
                               Foreground="{StaticResource B.Text}" VerticalAlignment="Center"/>

                    <Menu Background="Transparent" VerticalAlignment="Center" Margin="18,0,0,0" FontSize="13">
                        <MenuItem Header="{loc:Tr Menu_File}">
                            <MenuItem Header="{loc:Tr Menu_NewConnection}" Command="{Binding AddConnectionCommand}" InputGestureText="Ctrl+N"/>
                            <MenuItem Header="{loc:Tr Menu_NewQuery}" Command="{Binding OpenQueryCommand}" InputGestureText="Ctrl+Q"/>
                            <MenuItem Header="{loc:Tr Menu_QueryBuilder}" Command="{Binding OpenQueryBuilderCommand}" InputGestureText="Ctrl+B"/>
                            <Separator/>
                            <MenuItem Header="{loc:Tr Menu_ExportTable}" Command="{Binding SelectedTab.ExportCommand}"
                                      IsEnabled="{Binding SelectedTab, Converter={StaticResource NotNull}}"/>
                            <Separator/>
                            <MenuItem Header="{loc:Tr Menu_Settings}" Command="{Binding OpenSettingsCommand}"/>
                            <Separator/>
                            <MenuItem Header="{loc:Tr Menu_Exit}" Command="{Binding ExitAppCommand}" InputGestureText="Alt+F4"/>
                        </MenuItem>
                        <MenuItem Header="{loc:Tr Menu_Connection}">
                            <MenuItem Header="{loc:Tr Menu_AddConnection}" Command="{Binding AddConnectionCommand}"/>
                            <MenuItem Header="{loc:Tr Menu_EditConnection}" Command="{Binding EditConnectionCommand}"/>
                            <MenuItem Header="{loc:Tr Menu_RemoveConnection}" Command="{Binding RemoveConnectionCommand}"/>
                            <Separator/>
                            <MenuItem Header="{loc:Tr Menu_Refresh}" Command="{Binding RefreshNodeCommand}" InputGestureText="F5"/>
                        </MenuItem>
                        <MenuItem Header="{loc:Tr Menu_View}">
                            <MenuItem Header="{loc:Tr Menu_Refresh}" Command="{Binding RefreshNodeCommand}" InputGestureText="F5"/>
                            <Separator/>
                            <MenuItem Header="{loc:Tr Menu_StructurePanel}" IsCheckable="True"
                                      IsChecked="{Binding SelectedTab.ShowInspector, Mode=TwoWay}"
                                      IsEnabled="{Binding SelectedTab, Converter={StaticResource NotNull}}"/>
                            <MenuItem Header="{loc:Tr Menu_SqlPanel}" IsCheckable="True"
                                      IsChecked="{Binding SelectedTab.ShowSqlPanel, Mode=TwoWay}"
                                      IsEnabled="{Binding SelectedTab, Converter={StaticResource NotNull}}"/>
                            <MenuItem Header="{loc:Tr Menu_CellDetailPanel}" IsCheckable="True"
                                      IsChecked="{Binding SelectedTab.ShowDetailPanel, Mode=TwoWay}"
                                      IsEnabled="{Binding SelectedTab, Converter={StaticResource NotNull}}"/>
                        </MenuItem>
                        <MenuItem Header="{loc:Tr Menu_Help}">
                            <MenuItem Header="{loc:Tr Menu_Documentation}" Command="{Binding OpenDocsCommand}"
                                      InputGestureText="F1"/>
                            <MenuItem Header="{loc:Tr Menu_GitHub}" Command="{Binding OpenGitHubCommand}"/>
                            <MenuItem Header="{loc:Tr Menu_LatestRelease}" Command="{Binding OpenReleasesCommand}"/>
                            <Separator/>
                            <MenuItem Header="{loc:Tr Menu_About}" Command="{Binding ShowAboutCommand}"/>
                        </MenuItem>
                    </Menu>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===================== MAIN ===================== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="220"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource B.Sidebar}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- App logo header -->
                    <Border Grid.Row="0" Padding="12,12,12,10" BorderThickness="0,0,0,1"
                            BorderBrush="#1AFFFFFF">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image Source="/Assets/dataporticon.png" Width="28" Height="28"
                                   RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,9,0"/>
                            <TextBlock Text="DataPortStudio" FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource B.SidebarText}"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="1" Text="{loc:Tr Sidebar_Connections}" Margin="16,12,16,8"
                               FontSize="11" FontWeight="SemiBold" Opacity="0.7"
                               Foreground="{StaticResource B.SidebarText}"/>

                    <!-- Filter / locator -->
                    <Grid Grid.Row="2" Margin="10,0,10,8">
                        <TextBox Text="{Binding TreeFilter, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#FF2B3845" Foreground="{StaticResource B.SidebarText}"
                                 BorderBrush="#FF3A4A57" CaretBrush="White" Padding="8,5"
                                 ToolTip="{loc:Tr Filter_TablesTooltip}"/>
                        <TextBlock Text="{loc:Tr Filter_TablesPlaceholder}" Margin="11,0,0,0" VerticalAlignment="Center"
                                   Foreground="{StaticResource B.SidebarMuted}" IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TreeFilter}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="10,0,10,8">
                        <Button Style="{StaticResource ToolButton}" Foreground="{StaticResource B.SidebarText}"
                                Command="{Binding AddConnectionCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE710;"/><TextBlock Text="{loc:Tr Btn_Add}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ToolButton}" Foreground="{StaticResource B.SidebarText}"
                                Command="{Binding EditConnectionCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE70F;"/><TextBlock Text="{loc:Tr Btn_Edit}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ToolButton}" Foreground="{StaticResource B.SidebarText}"
                                Command="{Binding RemoveConnectionCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE74D;"/><TextBlock Text="{loc:Tr Btn_Remove}"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource ToolButton}" Foreground="{StaticResource B.SidebarText}"
                                Command="{Binding RefreshNodeCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE72C;"/><TextBlock Text="{loc:Tr Btn_Refresh}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TreeView x:Name="Tree" Grid.Row="4" Margin="8,0,8,10"
                              ItemsSource="{Binding Roots}"
                              SelectedItemChanged="Tree_SelectedItemChanged"
                              MouseDoubleClick="Tree_MouseDoubleClick"
                              PreviewMouseRightButtonDown="Tree_RightClick"
                              KeyDown="Tree_KeyDown">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="Visibility"
                                        Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" Background="{StaticResource B.Border}"/>

            <!-- Content -->
            <Grid Grid.Column="2">
                <!-- One tab strip: the persistent Objects tab + one tab per open table -->
                <TabControl ItemsSource="{Binding Tabs}"
                            SelectedItem="{Binding ActiveTab, Mode=TwoWay}"
                            Visibility="{Binding ActiveTab, Converter={StaticResource NullToVis}, ConverterParameter=inv}">
                    <TabControl.Resources>
                        <DataTemplate DataType="{x:Type vm:ObjectListViewModel}">
                            <v:ObjectListView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:TableTabViewModel}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*" MinHeight="120"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Per-table toolbar -->
                                <Border Grid.Row="0" Background="{StaticResource B.HeaderBar}"
                                        BorderBrush="{StaticResource B.Border}" BorderThickness="0,0,0,1" Padding="16,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Identifier}" FontSize="14" FontWeight="SemiBold"
                                                       Foreground="{StaticResource B.Text}" VerticalAlignment="Center"
                                                       MaxWidth="240" TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Identifier}"/>
                                            <Border Margin="12,0,0,0" Padding="8,3" CornerRadius="4" Background="#FFFDEAEA"
                                                    Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{loc:Tr Toolbar_Unsaved}" FontSize="11"
                                                           Foreground="{StaticResource B.Danger}"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Adaptive command bar: labels collapse to icons when tight,
                                             then extra items move into the » overflow menu. -->
                                        <Grid Grid.Column="1" x:Name="CommandHost" SizeChanged="CommandHost_SizeChanged">
                                            <ToolBarTray Background="Transparent" IsLocked="True" VerticalAlignment="Center">
                                                <ToolBar Style="{StaticResource CommandBar}">
                                                    <!-- Filter -->
                                                    <ToggleButton x:Name="FilterToggle"
                                                                  Style="{StaticResource ToolToggle}" Margin="0,0,6,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE71C;"/>
                                                            <TextBlock Style="{StaticResource ToolLabel}" Text="{loc:Tr Btn_Filter}"/>
                                                            <TextBlock Text=" ●" Foreground="{StaticResource B.Accent}"
                                                                       Visibility="{Binding HasActiveFilter, Converter={StaticResource BoolToVis}}"/>
                                                        </StackPanel>
                                                    </ToggleButton>

                                                    <!-- Sort -->
                                                    <ToggleButton x:Name="SortToggle"
                                                                  Style="{StaticResource ToolToggle}" Margin="0,0,6,0">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE8CB;"/>
                                                            <TextBlock Style="{StaticResource ToolLabel}" Text="{loc:Tr Btn_Sort}"/>
                                                            <TextBlock Text=" ●" Foreground="{StaticResource B.Accent}"
                                                                       Visibility="{Binding HasActiveSort, Converter={StaticResource BoolToVis}}"/>
                                                        </StackPanel>
                                                    </ToggleButton>

                                                    <Button Margin="0,0,6,0" Command="{Binding PickRowIdentityCommand}"
                                                            Style="{StaticResource ToolButton}"
                                                            Visibility="{Binding CanPickRowIdentity, Converter={StaticResource BoolToVis}}"
                                                            ToolTip="{loc:Tr Tip_RowIdentity}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE8D7;"/>
                                                            <TextBlock Style="{StaticResource ToolLabel}" Text="{loc:Tr Btn_RowIdentity}"/>
                                                        </StackPanel>
                                                    </Button>

                                                    <CheckBox Content="{Binding ClarionToggleLabel}" VerticalAlignment="Center"
                                                              Style="{StaticResource {x:Type CheckBox}}"
                                                              Margin="0,0,6,0" IsChecked="{Binding ShowClarionTypes}"
                                                              Visibility="{Binding HasClarionTypes, Converter={StaticResource BoolToVis}}"
                                                              ToolTip="Show Clarion date (days since 1800-12-28), time (centiseconds since midnight) and ts/sts/dts timestamp (epoch ms) fields in readable form"/>

                                                    <!-- View -->
                                                    <ToggleButton x:Name="ViewToggle"
                                                                  Style="{StaticResource ToolToggle}" Margin="0,0,6,0"
                                                                  IsChecked="{Binding ViewMenuOpen, Mode=TwoWay}"
                                                                  ToolTip="{loc:Tr Tip_View}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE890;"/>
                                                            <TextBlock Style="{StaticResource ToolLabel}" Text="{loc:Tr Btn_View}"/>
                                                        </StackPanel>
                                                    </ToggleButton>

                                                    <ToggleButton Style="{StaticResource ToolToggle}" Margin="0,0,6,0"
                                                                  IsChecked="{Binding ShowSqlPanel}"
                                                                  ToolTip="{loc:Tr Tip_SQL}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE943;"/>
                                                            <TextBlock Style="{StaticResource ToolLabel}" Text="{loc:Tr Btn_SQL}"/>
                                                        </StackPanel>
                                                    </ToggleButton>

                                                    <ToggleButton Style="{StaticResource ToolToggle}" Margin="0,0,6,0"
                                                                  IsChecked="{Binding ShowInspector}"
                                                                  ToolTip="{loc:Tr Tip_Structure}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE8A5;"/>
                                                            <TextBlock Style="{StaticResource ToolLabel}" Text="{loc:Tr Btn_Structure}"/>
                                                        </StackPanel>
                                                    </ToggleButton>

                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,6,0">
                                                        <TextBlock Text="{loc:Tr Lbl_RowLimit}" VerticalAlignment="Center" FontSize="12"
                                                                   Foreground="{StaticResource B.TextMuted}" Margin="0,0,8,0"/>
                                                        <TextBox Width="72" VerticalAlignment="Center"
                                                                 Text="{Binding RowLimit, UpdateSourceTrigger=LostFocus}"/>
                                                    </StackPanel>

                                                    <Button Margin="0,0,6,0" Command="{Binding ExportCommand}"
                                                            Style="{StaticResource ToolButton}" ToolTip="{loc:Tr Tip_Export}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource ToolIcon}" Text="&#xEDE1;"/>
                                                            <TextBlock Style="{StaticResource ToolLabel}" Text="{loc:Tr Btn_Export}"/>
                                                        </StackPanel>
                                                    </Button>

                                                    <Button Margin="0,0,6,0" Command="{Binding ReloadCommand}"
                                                            Style="{StaticResource ToolButton}" ToolTip="{loc:Tr Btn_Reload}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE72C;"/>
                                                            <TextBlock Style="{StaticResource ToolLabel}" Text="{loc:Tr Btn_Reload}"/>
                                                        </StackPanel>
                                                    </Button>

                                                    <Button ToolBar.OverflowMode="Never" Margin="0,0,0,0"
                                                            Style="{StaticResource AccentButton}"
                                                            Command="{Binding SaveChangesCommand}"
                                                            IsEnabled="{Binding HasUnsavedChanges}"
                                                            ToolTip="{loc:Tr Btn_SaveChanges}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE74E;"/>
                                                            <TextBlock Style="{StaticResource ToolLabel}" Text="{loc:Tr Btn_SaveChanges}"/>
                                                        </StackPanel>
                                                    </Button>
                                                </ToolBar>
                                            </ToolBarTray>

                                            <!-- Popups live outside the ToolBar so they anchor to their
                                                 toggles by name even when items reflow. -->
                                            <Popup PlacementTarget="{Binding ElementName=FilterToggle}" Placement="Bottom"
                                                   StaysOpen="False" AllowsTransparency="True"
                                                   IsOpen="{Binding IsChecked, ElementName=FilterToggle, Mode=TwoWay}">
                                                <Border Background="{StaticResource B.Surface}" CornerRadius="8" Margin="6"
                                                        BorderBrush="{StaticResource B.Border}" BorderThickness="1" Width="520">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.2" Color="#FF1F2933"/>
                                                    </Border.Effect>
                                                    <StackPanel Margin="14">
                                                        <TextBlock Text="{loc:Tr Filter_Title}" Style="{StaticResource H1}" Margin="0,0,0,8"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                            <RadioButton Content="{loc:Tr Filter_MatchAll}" GroupName="Match"
                                                                         IsChecked="{Binding FilterMatchAll}"/>
                                                            <RadioButton Content="{loc:Tr Filter_MatchAny}" GroupName="Match"/>
                                                        </StackPanel>
                                                        <ItemsControl ItemsSource="{Binding FilterConditions}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,3">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="6"/>
                                                                            <ColumnDefinition Width="120"/>
                                                                            <ColumnDefinition Width="6"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="6"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <ComboBox Grid.Column="0" SelectedItem="{Binding Column}"
                                                                                  ItemsSource="{Binding DataContext.ColumnNames, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                                        <ComboBox Grid.Column="2" SelectedItem="{Binding Operator}"
                                                                                  ItemsSource="{Binding DataContext.FilterOperators, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                                        <TextBox Grid.Column="4" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                                                                        <Button Grid.Column="6" Content="✕" Width="28"
                                                                                Command="{Binding DataContext.RemoveFilterConditionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                CommandParameter="{Binding}"/>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                            <Button Content="{loc:Tr Filter_AddCondition}" Command="{Binding AddFilterConditionCommand}"/>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                                        FlowDirection="LeftToRight" Margin="0">
                                                                <Button Content="{loc:Tr Btn_Clear}" Margin="8,0,0,0" Command="{Binding ClearFilterCommand}"/>
                                                                <Button Content="{loc:Tr Btn_Apply}" Margin="8,0,0,0" Style="{StaticResource AccentButton}"
                                                                        Command="{Binding ApplyFilterCommand}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>

                                            <Popup PlacementTarget="{Binding ElementName=SortToggle}" Placement="Bottom"
                                                   StaysOpen="False" AllowsTransparency="True"
                                                   IsOpen="{Binding IsChecked, ElementName=SortToggle, Mode=TwoWay}">
                                                <Border Background="{StaticResource B.Surface}" CornerRadius="8" Margin="6"
                                                        BorderBrush="{StaticResource B.Border}" BorderThickness="1" Width="420">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.2" Color="#FF1F2933"/>
                                                    </Border.Effect>
                                                    <StackPanel Margin="14">
                                                        <TextBlock Text="{loc:Tr Sort_Title}" Style="{StaticResource H1}" Margin="0,0,0,8"/>
                                                        <ItemsControl ItemsSource="{Binding SortLevels}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,3">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="6"/>
                                                                            <ColumnDefinition Width="110"/>
                                                                            <ColumnDefinition Width="6"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <ComboBox Grid.Column="0" SelectedItem="{Binding Column}"
                                                                                  ItemsSource="{Binding DataContext.ColumnNames, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                                        <ComboBox Grid.Column="2" SelectedItem="{Binding Direction}"
                                                                                  ItemsSource="{Binding DataContext.SortDirections, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                                        <Button Grid.Column="4" Content="✕" Width="28"
                                                                                Command="{Binding DataContext.RemoveSortLevelCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                CommandParameter="{Binding}"/>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                            <Button Content="{loc:Tr Sort_AddLevel}" Command="{Binding AddSortLevelCommand}"/>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                                <Button Content="{loc:Tr Btn_Clear}" Margin="8,0,0,0" Command="{Binding ClearSortCommand}"/>
                                                                <Button Content="{loc:Tr Btn_Apply}" Margin="8,0,0,0" Style="{StaticResource AccentButton}"
                                                                        Command="{Binding ApplySortCommand}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>

                                            <Popup PlacementTarget="{Binding ElementName=ViewToggle}" Placement="Bottom"
                                                   StaysOpen="False" AllowsTransparency="True"
                                                   IsOpen="{Binding ViewMenuOpen, Mode=TwoWay}">
                                                <Border Background="{StaticResource B.Surface}" CornerRadius="8" Margin="6" Width="172"
                                                        BorderBrush="{StaticResource B.Border}" BorderThickness="1">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.2" Color="#FF1F2933"/>
                                                    </Border.Effect>
                                                    <StackPanel Margin="4">
                                                        <Button Style="{StaticResource MenuItemButton}" Content="{loc:Tr View_Auto}"
                                                                Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static vm:CellViewMode.Auto}"/>
                                                        <Button Style="{StaticResource MenuItemButton}" Content="{loc:Tr View_Text}"
                                                                Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static vm:CellViewMode.Text}"/>
                                                        <Button Style="{StaticResource MenuItemButton}" Content="{loc:Tr View_Hex}"
                                                                Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static vm:CellViewMode.Hex}"/>
                                                        <Button Style="{StaticResource MenuItemButton}" Content="{loc:Tr View_Image}"
                                                                Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static vm:CellViewMode.Image}"/>
                                                        <Button Style="{StaticResource MenuItemButton}" Content="{loc:Tr View_Web}"
                                                                Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static vm:CellViewMode.Web}"/>
                                                        <Separator Margin="6,4"/>
                                                        <Button Style="{StaticResource MenuItemButton}" Content="{loc:Tr View_HidePanel}"
                                                                Command="{Binding HideDetailPanelCommand}"/>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <DataGrid Grid.Row="1" Margin="16,16,16,8"
                                          ItemsSource="{Binding GridData}"
                                          IsReadOnly="{Binding GridReadOnly}"
                                          CanUserAddRows="{Binding GridCanModifyRows}" CanUserDeleteRows="{Binding GridCanModifyRows}"
                                          AutoGenerateColumns="True"
                                          beh:DataGridClarion.Enabled="True"/>

                                <!-- Cell detail pane (docked, resizable) -->
                                <Grid Grid.Row="2">
                                    <Grid.Visibility>
                                        <MultiBinding Converter="{StaticResource ShownNotPopped}">
                                            <Binding Path="ShowDetailPanel"/>
                                            <Binding Path="DetailPopped"/>
                                        </MultiBinding>
                                    </Grid.Visibility>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Thumb Grid.Row="0" Style="{StaticResource PaneThumb}" Tag="detail"
                                           DragDelta="PaneThumb_DragDelta"/>
                                    <Border Grid.Row="1" Height="{Binding DetailPaneHeight}" Margin="16,0,16,16"
                                            Background="{StaticResource B.Surface}" CornerRadius="8"
                                            BorderBrush="{StaticResource B.Border}" BorderThickness="1">
                                        <v:CellDetailView/>
                                    </Border>
                                </Grid>

                                <!-- SQL preview pane (docked, resizable) -->
                                <Grid Grid.Row="3">
                                    <Grid.Visibility>
                                        <MultiBinding Converter="{StaticResource ShownNotPopped}">
                                            <Binding Path="ShowSqlPanel"/>
                                            <Binding Path="SqlPopped"/>
                                        </MultiBinding>
                                    </Grid.Visibility>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Thumb Grid.Row="0" Style="{StaticResource PaneThumb}" Tag="sql"
                                           DragDelta="PaneThumb_DragDelta"/>
                                    <Border Grid.Row="1" Height="{Binding SqlPaneHeight}" Margin="16,0,16,16"
                                            Background="{StaticResource B.Surface}" CornerRadius="8"
                                            BorderBrush="{StaticResource B.Border}" BorderThickness="1">
                                        <v:SqlPreviewView/>
                                    </Border>
                                </Grid>
                                </Grid>

                                <Thumb Grid.Column="1" Style="{StaticResource PaneThumbV}" Tag="inspector"
                                       DragDelta="PaneThumb_DragDelta">
                                    <Thumb.Visibility>
                                        <MultiBinding Converter="{StaticResource ShownNotPopped}">
                                            <Binding Path="ShowInspector"/>
                                            <Binding Path="InspectorPopped"/>
                                        </MultiBinding>
                                    </Thumb.Visibility>
                                </Thumb>

                                <Border Grid.Column="2" Width="{Binding InspectorWidth}"
                                        Background="{StaticResource B.Surface}"
                                        BorderBrush="{StaticResource B.Border}" BorderThickness="1,0,0,0">
                                    <Border.Visibility>
                                        <MultiBinding Converter="{StaticResource ShownNotPopped}">
                                            <Binding Path="ShowInspector"/>
                                            <Binding Path="InspectorPopped"/>
                                        </MultiBinding>
                                    </Border.Visibility>
                                    <v:InspectorView/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </TabControl.Resources>
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                        ToolTip="{Binding TabToolTip}" ToolTipService.ShowDuration="20000">
                                <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,7,0"
                                      Data="M2.5,3.5 H13.5 V12.5 H2.5 Z M2.5,6.5 H13.5 M2.5,9.5 H13.5 M6.17,3.5 V12.5 M9.83,3.5 V12.5"
                                      Stroke="#FF4C6275" StrokeThickness="1.2" Fill="Transparent"/>
                                <TextBlock Text="{Binding Header}" VerticalAlignment="Center"/>
                                <TextBlock Text="●" Margin="6,0,0,0" FontSize="9" VerticalAlignment="Center"
                                           Foreground="{StaticResource B.Danger}"
                                           Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>
                                <Button Style="{StaticResource TabCloseButton}" Margin="8,0,-4,0"
                                        Command="{Binding CloseCommand}"
                                        Visibility="{Binding CanClose, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                </TabControl>

                <!-- Empty state (no tabs open) -->
                <Border Margin="16" Background="{StaticResource B.Surface}" CornerRadius="10"
                        BorderBrush="{StaticResource B.Border}" BorderThickness="1"
                        Visibility="{Binding ShowEmpty, Converter={StaticResource BoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Path Data="M2.5,3.5 H13.5 V12.5 H2.5 Z M2.5,6.5 H13.5 M2.5,9.5 H13.5 M6.17,3.5 V12.5 M9.83,3.5 V12.5"
                              Width="48" Height="48" Stretch="Uniform"
                              Stroke="{StaticResource B.BorderStrong}" StrokeThickness="0.7"/>
                        <TextBlock Text="{loc:Tr Empty_NoTable}" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource B.Text}" HorizontalAlignment="Center" Margin="0,16,0,4"/>
                        <TextBlock Text="{loc:Tr Empty_Hint}"
                                   FontSize="13" Foreground="{StaticResource B.TextMuted}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ===================== STATUS BAR ===================== -->
        <Border Grid.Row="3" Background="{StaticResource B.Sidebar}" Padding="16,6">
            <Grid>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource B.SidebarText}"
                           FontSize="12" VerticalAlignment="Center"/>
                <ProgressBar Width="140" Height="6" IsIndeterminate="True" HorizontalAlignment="Right"
                             Background="Transparent" BorderThickness="0" Foreground="{StaticResource B.Accent}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
