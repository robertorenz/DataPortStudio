<Window x:Class="DataPortStudio.Views.QueryBuilderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Query Builder" Height="660" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource B.Bg}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="470"/>
            <ColumnDefinition Width="*" MinWidth="360"/>
        </Grid.ColumnDefinitions>

        <!-- Builder -->
        <Border Grid.Column="0" Background="{StaticResource B.Surface}"
                BorderBrush="{StaticResource B.Border}" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                <StackPanel>
                    <!-- Tables -->
                    <TextBlock Text="Tables" Style="{StaticResource H1}" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ComboBox Width="320" ItemsSource="{Binding AllTables}"
                                  SelectedItem="{Binding SelectedTableToAdd}" IsEditable="True"/>
                        <Button Content="Add table" Margin="8,0,0,0" Command="{Binding AddTableCommand}"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{Binding Tables}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource B.Border}" BorderThickness="1" CornerRadius="6"
                                        Margin="0,0,0,8" Padding="8">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{Binding Display}" FontWeight="SemiBold"
                                                       Foreground="{StaticResource B.Text}" VerticalAlignment="Center"/>
                                            <Button Content="✕" Width="22" HorizontalAlignment="Right" Style="{StaticResource ToolButton}"
                                                    Command="{Binding DataContext.RemoveTableCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding Columns}" Margin="0,4,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding Included}" Margin="0,2,12,2"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Joins -->
                    <Grid Margin="0,8,0,6">
                        <TextBlock Text="Joins" Style="{StaticResource H1}" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Detect from FKs" Command="{Binding DetectJoinsCommand}"/>
                            <Button Content="＋" Width="30" Margin="6,0,0,0" Command="{Binding AddJoinCommand}"/>
                        </StackPanel>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Joins}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="90"/><ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" SelectedItem="{Binding LeftColumn}"
                                              ItemsSource="{Binding DataContext.AvailableColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                    <ComboBox Grid.Column="2" SelectedItem="{Binding JoinType}"
                                              ItemsSource="{Binding DataContext.JoinTypes, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                    <ComboBox Grid.Column="4" SelectedItem="{Binding RightColumn}"
                                              ItemsSource="{Binding DataContext.AvailableColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                    <Button Grid.Column="6" Content="✕" Width="26"
                                            Command="{Binding DataContext.RemoveJoinCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Filters -->
                    <Grid Margin="0,12,0,6">
                        <TextBlock Text="Filters" Style="{StaticResource H1}" VerticalAlignment="Center"/>
                        <Button Content="＋" Width="30" HorizontalAlignment="Right" Command="{Binding AddFilterCommand}"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Filters}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/><ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="120"/><ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" SelectedItem="{Binding Connector}"
                                              ItemsSource="{Binding DataContext.Connectors, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                    <ComboBox Grid.Column="2" SelectedItem="{Binding Column}"
                                              ItemsSource="{Binding DataContext.AvailableColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                    <ComboBox Grid.Column="4" SelectedItem="{Binding Operator}"
                                              ItemsSource="{Binding DataContext.FilterOperatorValues, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                    <TextBox Grid.Column="6" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Grid.Column="8" Content="✕" Width="26"
                                            Command="{Binding DataContext.RemoveFilterCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Sort -->
                    <Grid Margin="0,12,0,6">
                        <TextBlock Text="Sort" Style="{StaticResource H1}" VerticalAlignment="Center"/>
                        <Button Content="＋" Width="30" HorizontalAlignment="Right" Command="{Binding AddSortCommand}"/>
                    </Grid>
                    <ItemsControl ItemsSource="{Binding Sorts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="100"/><ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" SelectedItem="{Binding Column}"
                                              ItemsSource="{Binding DataContext.AvailableColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                    <ComboBox Grid.Column="2" SelectedItem="{Binding Direction}"
                                              ItemsSource="{Binding DataContext.SortDirections, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                    <Button Grid.Column="4" Content="✕" Width="26"
                                            Command="{Binding DataContext.RemoveSortCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- SQL + results -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2*" MinHeight="80"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="3*" MinHeight="120"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource B.HeaderBar}"
                    BorderBrush="{StaticResource B.Border}" BorderThickness="0,0,0,1" Padding="14,10">
                <Grid>
                    <TextBlock Text="Generated SQL" FontWeight="SemiBold" VerticalAlignment="Center"
                               Foreground="{StaticResource B.Text}"/>
                    <Button HorizontalAlignment="Right" Style="{StaticResource AccentButton}" Command="{Binding RunCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE768;"/><TextBlock Text="Run"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1" Margin="12,12,12,0" BorderBrush="{StaticResource B.Border}" BorderThickness="1" CornerRadius="6">
                <TextBox Text="{Binding GeneratedSql, Mode=OneWay}" IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top" FontFamily="Consolas" FontSize="13"
                         BorderThickness="0" Padding="8"/>
            </Border>

            <GridSplitter Grid.Row="2" Height="8" Margin="12,4" HorizontalAlignment="Stretch"
                          VerticalAlignment="Center" ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                          Style="{StaticResource PaneSplitter}"/>

            <DataGrid Grid.Row="3" Margin="12,0,12,8" ItemsSource="{Binding Results}"
                      IsReadOnly="True" AutoGenerateColumns="True" CanUserAddRows="False"/>

            <Border Grid.Row="4" Background="{StaticResource B.Sidebar}" Padding="14,6">
                <TextBlock Text="{Binding Messages}" Foreground="{StaticResource B.SidebarText}" FontSize="12"/>
            </Border>
        </Grid>
    </Grid>
</Window>
