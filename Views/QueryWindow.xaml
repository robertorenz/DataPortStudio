<Window x:Class="DataPortStudio.Views.QueryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Query" Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource B.Bg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*" MinHeight="80"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*" MinHeight="120"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource B.HeaderBar}"
                BorderBrush="{StaticResource B.Border}" BorderThickness="0,0,0,1" Padding="14,10">
            <Grid>
                <TextBlock x:Name="TargetLabel" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource B.Text}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="RunButton" Style="{StaticResource AccentButton}" Click="Run_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE768;"/>
                            <TextBlock Text="Run  (F5 / Ctrl+E)"/>
                        </StackPanel>
                    </Button>
                    <Button Content="Clear" Margin="10,0,0,0" Click="Clear_Click"/>
                    <Button Content="Format  (Ctrl+Shift+F)" Margin="10,0,0,0" Click="Format_Click" ToolTip="Beautify SQL"/>
                    <!-- History button + popup -->
                    <Button x:Name="HistoryButton" Content="⏱ History" Margin="10,0,0,0"
                            Click="History_Click" ToolTip="Recent queries (Ctrl+H)"/>
                    <Popup x:Name="HistoryPopup" StaysOpen="False"
                           PlacementTarget="{Binding ElementName=HistoryButton}"
                           Placement="Bottom" AllowsTransparency="True">
                        <Border Background="{StaticResource B.Surface}"
                                BorderBrush="{StaticResource B.Border}" BorderThickness="1"
                                CornerRadius="6" Width="560" MaxHeight="320">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.2" Color="#FF000000"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{StaticResource B.SurfaceAlt}"
                                        BorderBrush="{StaticResource B.Border}" BorderThickness="0,0,0,1"
                                        Padding="12,8">
                                    <TextBlock Text="Recent queries — click to load · double-click to run"
                                               FontSize="11" Foreground="{StaticResource B.TextMuted}"/>
                                </Border>
                                <ListBox x:Name="HistoryList" Grid.Row="1"
                                         Background="Transparent" BorderThickness="0"
                                         MouseDoubleClick="HistoryList_DoubleClick"
                                         SelectionChanged="HistoryList_SelectionChanged">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="12,7"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Preview}" FontFamily="Consolas" FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{StaticResource B.Text}"
                                                       ToolTip="{Binding Sql}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>
                    </Popup>
                    <Button Content="Load…" Margin="10,0,0,0" Click="Load_Click" ToolTip="Load SQL script from file  (Ctrl+O)"/>
                    <Button Content="Save…" Margin="10,0,0,0" Click="Save_Click" ToolTip="Save SQL script to file  (Ctrl+S)"/>
                    <Button x:Name="ExportButton" Content="Export…" Margin="10,0,0,0" Click="Export_Click" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- SQL editor -->
        <Border Grid.Row="1" Margin="12,12,12,0" BorderBrush="{StaticResource B.Border}" BorderThickness="1" CornerRadius="6">
            <avalon:TextEditor x:Name="Editor"
                               VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                               BorderThickness="0" WordWrap="False"/>
        </Border>

        <GridSplitter Grid.Row="2" Height="8" Margin="12,4" HorizontalAlignment="Stretch"
                      VerticalAlignment="Center" ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                      Style="{StaticResource PaneSplitter}"/>

        <!-- Results: TabControl, one tab per resultset -->
        <TabControl x:Name="ResultTabs" Grid.Row="3" Margin="12,0,12,8"
                    Background="{StaticResource B.Surface}"/>

        <!-- Messages -->
        <Border Grid.Row="4" Background="{StaticResource B.Sidebar}" Padding="14,6">
            <TextBlock x:Name="Messages" Foreground="{StaticResource B.SidebarText}" FontSize="12"
                       VerticalAlignment="Center" Text="Ready. Type SQL and press F5 to run."/>
        </Border>
    </Grid>
</Window>
