<Window x:Class="DataPortStudio.Views.ColumnMappingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" SizeToContent="Height"
        ShowInTaskbar="False" Width="660">
    <Border Background="{StaticResource B.Surface}" CornerRadius="12" Margin="16"
            BorderBrush="{StaticResource B.Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.25" Color="#FF1F2933"/>
        </Border.Effect>
        <StackPanel>
            <!-- Header -->
            <Border Background="{StaticResource B.Sidebar}" CornerRadius="12,12,0,0" Padding="20,16"
                    MouseLeftButtonDown="Header_MouseDown">
                <StackPanel>
                    <TextBlock x:Name="TitleText" Text="Review column types"
                               FontSize="16" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock x:Name="SubtitleText" Margin="0,4,0,0" FontSize="12"
                               Foreground="#FFB7C2CE" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Body -->
            <StackPanel Margin="22,16,22,8">
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource B.TextMuted}" Margin="0,0,0,12"
                           Text="Each Clarion column is mapped to a SQL type below. Pick a SQL type and set a size where it applies (length for text, precision,scale for decimal). Detected Clarion dates/times are pre-set to date/time and converted on copy. The table is created with these types, then the rows are copied in."/>

                <!-- Column headers -->
                <Grid Margin="2,0,2,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="95"/>
                        <ColumnDefinition Width="165"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Column" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource B.TextMuted}"/>
                    <TextBlock Grid.Column="1" Text="Clarion type" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource B.TextMuted}"/>
                    <TextBlock Grid.Column="2" Text="SQL type" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource B.TextMuted}"/>
                    <TextBlock Grid.Column="3" Text="Size" FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource B.TextMuted}"/>
                </Grid>

                <Border BorderBrush="{StaticResource B.Border}" BorderThickness="1" CornerRadius="6">
                    <ScrollViewer MaxHeight="380" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="RowList" Margin="6">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="165"/>
                                            <ColumnDefinition Width="90"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" Margin="2,0,8,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SourceType}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" Foreground="{StaticResource B.TextMuted}" FontSize="11"/>
                                        <ComboBox Grid.Column="2" Margin="0,0,8,0" IsEditable="True"
                                                  ItemsSource="{Binding BaseTypes}"
                                                  Text="{Binding BaseType, UpdateSourceTrigger=PropertyChanged}"/>
                                        <TextBox Grid.Column="3" VerticalContentAlignment="Center"
                                                 Text="{Binding Size, UpdateSourceTrigger=PropertyChanged}"
                                                 IsEnabled="{Binding SizeEnabled}"
                                                 ToolTip="Length (e.g. 80 or max), or precision,scale for decimal"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- Footer -->
            <Border Background="{StaticResource B.SurfaceAlt}" CornerRadius="0,0,12,12"
                    BorderBrush="{StaticResource B.Border}" BorderThickness="0,1,0,0" Padding="16,14">
                <Grid>
                    <Button Content="Reset to suggested" MinWidth="120" HorizontalAlignment="Left"
                            Click="Reset_Click"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" MinWidth="90" Margin="0,0,10,0" Click="Cancel_Click"/>
                        <Button Content="Apply &amp; copy" MinWidth="110" Style="{StaticResource AccentButton}"
                                Click="Apply_Click" IsDefault="True"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </Border>
</Window>
