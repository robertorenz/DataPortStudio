<Window x:Class="DataPortStudio.Views.TableDesignerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Table Designer" Height="640" Width="940"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource B.Bg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="2*" MinHeight="120"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="80"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource B.HeaderBar}"
                BorderBrush="{StaticResource B.Border}" BorderThickness="0,0,0,1" Padding="14,10">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Table name" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{StaticResource B.TextMuted}"/>
                    <TextBox Width="220" Text="{Binding TableName, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Content="＋ Add column" Margin="12,0,0,0" Command="{Binding AddColumnCommand}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Copy script" Margin="0,0,10,0" Command="{Binding CopyScriptCommand}"/>
                    <Button Style="{StaticResource AccentButton}" Command="{Binding SaveCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE74E;"/><TextBlock Text="Save"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="12,12,12,0" Background="Transparent" BorderThickness="0">
            <TabItem Header="Columns">
                <DataGrid ItemsSource="{Binding Columns}" AutoGenerateColumns="False" CanUserAddRows="False"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTemplateColumn Header="Type" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ComboBox IsEditable="True" SelectedItem="{Binding Type}" Text="{Binding Type, UpdateSourceTrigger=LostFocus}"
                                              ItemsSource="{Binding DataContext.DataTypes, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              BorderThickness="0" Background="Transparent"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Size" Binding="{Binding Size, UpdateSourceTrigger=PropertyChanged}" Width="80"/>
                        <DataGridCheckBoxColumn Header="Null" Binding="{Binding Nullable, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                        <DataGridCheckBoxColumn Header="Identity" Binding="{Binding Identity, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                        <DataGridCheckBoxColumn Header="PK" Binding="{Binding PrimaryKey, UpdateSourceTrigger=PropertyChanged}" Width="44"/>
                        <DataGridTextColumn Header="Default" Binding="{Binding DefaultValue, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                        <DataGridTemplateColumn Width="36">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" Width="26" Style="{StaticResource ToolButton}"
                                            Command="{Binding DataContext.RemoveColumnCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Indexes">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="＋ Add index" HorizontalAlignment="Left" Margin="0,6,0,6"
                            Command="{Binding AddIndexCommand}"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Indexes}" AutoGenerateColumns="False"
                              CanUserAddRows="False" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                            <DataGridTextColumn Header="Columns (comma-separated)" Binding="{Binding Columns, UpdateSourceTrigger=PropertyChanged}" Width="2*"/>
                            <DataGridCheckBoxColumn Header="Unique" Binding="{Binding Unique, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                            <DataGridTemplateColumn Width="36">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" Width="26" Style="{StaticResource ToolButton}"
                                                Command="{Binding DataContext.RemoveIndexCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <GridSplitter Grid.Row="2" Height="8" Margin="12,4" HorizontalAlignment="Stretch"
                      VerticalAlignment="Center" ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                      Style="{StaticResource PaneSplitter}"/>

        <Border Grid.Row="3" Margin="12,0,12,8" BorderBrush="{StaticResource B.Border}" BorderThickness="1" CornerRadius="6">
            <TextBox Text="{Binding GeneratedSql, Mode=OneWay}" IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                     VerticalContentAlignment="Top" FontFamily="Consolas" FontSize="13"
                     BorderThickness="0" Padding="8"/>
        </Border>

        <Border Grid.Row="4" Background="{StaticResource B.Sidebar}" Padding="14,6">
            <TextBlock Text="{Binding Messages}" Foreground="{StaticResource B.SidebarText}" FontSize="12"/>
        </Border>
    </Grid>
</Window>
