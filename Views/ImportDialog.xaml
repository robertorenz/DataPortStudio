<Window x:Class="DataPortStudio.Views.ImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:DataPortStudio.Services"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" SizeToContent="Height"
        ShowInTaskbar="False" Width="560">
    <Border Background="{StaticResource B.Surface}" CornerRadius="12" Margin="16"
            BorderBrush="{StaticResource B.Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.25" Color="#FF1F2933"/>
        </Border.Effect>
        <StackPanel>
            <Border Background="{StaticResource B.Sidebar}" CornerRadius="12,12,0,0" Padding="20,16"
                    MouseLeftButtonDown="Header_MouseDown">
                <TextBlock x:Name="HeaderText" Text="Import data" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
            </Border>

            <StackPanel Margin="22,16,22,8">
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="FileBox" IsReadOnly="True" VerticalContentAlignment="Center"
                             Padding="8,6" Foreground="{StaticResource B.TextMuted}"/>
                    <Button Grid.Column="1" Content="{loc:Tr Btn_Browse}" MinWidth="90" Margin="8,0,0,0" Click="Browse_Click"/>
                </Grid>

                <CheckBox x:Name="HeaderCheck" Content="{loc:Tr Import_FirstRowHeader}"
                          IsChecked="True" Margin="0,0,0,12" Click="HeaderCheck_Click"/>

                <TextBlock Text="{loc:Tr Import_MapColumns}" FontWeight="SemiBold" FontSize="12"
                           Foreground="{StaticResource B.TextMuted}" Margin="0,0,0,6"/>

                <Border BorderBrush="{StaticResource B.Border}" BorderThickness="1" CornerRadius="6">
                    <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="MappingList" Margin="6">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding TableColumn}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding TypeLabel}" Margin="6,0,0,0"
                                                       Foreground="{StaticResource B.TextMuted}" FontSize="11" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="←" Margin="10,0" VerticalAlignment="Center"
                                                   Foreground="{StaticResource B.TextMuted}"/>
                                        <ComboBox Grid.Column="2" ItemsSource="{Binding SourceOptions}"
                                                  SelectedItem="{Binding SelectedSource, Mode=TwoWay}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <TextBlock x:Name="PreviewText" Margin="2,8,0,0" FontSize="12"
                           Foreground="{StaticResource B.TextMuted}"/>
            </StackPanel>

            <Border Background="{StaticResource B.SurfaceAlt}" CornerRadius="0,0,12,12"
                    BorderBrush="{StaticResource B.Border}" BorderThickness="0,1,0,0" Padding="16,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{loc:Tr Btn_Cancel}" MinWidth="90" Margin="0,0,10,0" Click="Cancel_Click"/>
                    <Button x:Name="ImportButton" Content="{loc:Tr Import_Button}" MinWidth="100" Style="{StaticResource AccentButton}"
                            Click="Import_Click" IsDefault="True" IsEnabled="False"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>
