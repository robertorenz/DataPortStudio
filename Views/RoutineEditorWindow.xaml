<Window x:Class="DataPortStudio.Views.RoutineEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Edit Routine" Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource B.Bg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource B.HeaderBar}"
                BorderBrush="{StaticResource B.Border}" BorderThickness="0,0,0,1" Padding="14,10">
            <Grid>
                <TextBlock x:Name="TitleLabel" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                           Foreground="{StaticResource B.Text}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Load…" Margin="0,0,10,0" Click="LoadFile_Click" ToolTip="Load SQL script from file  (Ctrl+O)"/>
                <Button Content="Save…" Margin="0,0,10,0" Click="SaveFile_Click" ToolTip="Save SQL script to file  (Ctrl+Shift+S)"/>
                <Button Content="Format  (Ctrl+Shift+F)" Margin="0,0,10,0" Click="Format_Click" ToolTip="Beautify SQL"/>
                <Button x:Name="SaveButton" Style="{StaticResource AccentButton}" Click="Save_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE74E;"/>
                        <TextBlock Text="Save  (Ctrl+S)"/>
                    </StackPanel>
                </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Margin="12" BorderBrush="{StaticResource B.Border}" BorderThickness="1" CornerRadius="6">
            <avalon:TextEditor x:Name="Editor"
                               VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                               BorderThickness="0" WordWrap="False"/>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource B.Sidebar}" Padding="14,6">
            <TextBlock x:Name="Messages" Foreground="{StaticResource B.SidebarText}" FontSize="12"
                       VerticalAlignment="Center" Text="Loading…"/>
        </Border>
    </Grid>
</Window>
