<Window x:Class="DataPortStudio.Views.ModalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" SizeToContent="Height"
        ShowInTaskbar="False" Width="420">
    <Border Background="{StaticResource B.Surface}" CornerRadius="12" Margin="16"
            BorderBrush="{StaticResource B.Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.25" Color="#FF1F2933"/>
        </Border.Effect>
        <StackPanel>
            <!-- Header (draggable) -->
            <Border x:Name="HeaderBar" CornerRadius="12,12,0,0" Padding="20,16"
                    MouseLeftButtonDown="Header_MouseDown">
                <StackPanel Orientation="Horizontal">
                    <Border x:Name="IconBadge" Width="34" Height="34" CornerRadius="17"
                            Background="{StaticResource B.Accent}" VerticalAlignment="Center">
                        <TextBlock x:Name="IconGlyph" Text="i" FontSize="18" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TitleText" Text="Title" Margin="14,0,0,0"
                               FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"
                               Foreground="{StaticResource B.Text}"/>
                </StackPanel>
            </Border>

            <!-- Message -->
            <TextBlock x:Name="MessageText" Margin="20,0,20,20" TextWrapping="Wrap"
                       FontSize="13" LineHeight="20" Foreground="{StaticResource B.TextMuted}"/>

            <!-- Buttons -->
            <Border Background="{StaticResource B.SurfaceAlt}" CornerRadius="0,0,12,12"
                    BorderBrush="{StaticResource B.Border}" BorderThickness="0,1,0,0" Padding="16,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="SecondaryButton" Content="Cancel" MinWidth="90"
                            Margin="0,0,10,0" Click="Secondary_Click" Visibility="Collapsed"/>
                    <Button x:Name="MiddleButton" Content="" MinWidth="90"
                            Margin="0,0,10,0" Click="Middle_Click" Visibility="Collapsed"/>
                    <Button x:Name="PrimaryButton" Content="OK" MinWidth="90"
                            Style="{StaticResource AccentButton}" Click="Primary_Click" IsDefault="True"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>
