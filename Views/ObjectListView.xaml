<UserControl x:Class="DataPortStudio.Views.ObjectListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:DataPortStudio.Services"
             Background="{StaticResource B.Bg}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource B.HeaderBar}"
                BorderBrush="{StaticResource B.Border}" BorderThickness="0,0,0,1" Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding OpenCommand}" Style="{StaticResource ToolButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE8A7;"/><TextBlock Text="{loc:Tr OL_OpenTable}"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding DesignCommand}" Style="{StaticResource ToolButton}"
                        Visibility="{Binding CanDesign, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE70F;"/><TextBlock Text="{loc:Tr OL_DesignTable}"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding NewCommand}" Style="{StaticResource ToolButton}"
                        Visibility="{Binding CanCreate, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE710;"/><TextBlock Text="{loc:Tr OL_NewTable}"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding DeleteCommand}" Style="{StaticResource ToolButton}"
                        Visibility="{Binding CanDelete, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE74D;"/><TextBlock Text="{loc:Tr OL_DeleteTable}"/>
                    </StackPanel>
                </Button>
                <Border Width="1" Background="{StaticResource B.Border}" Margin="6,2"
                        Visibility="{Binding IsTables, Converter={StaticResource BoolToVis}}"/>
                <Button Command="{Binding CopyCommand}" Style="{StaticResource ToolButton}"
                        Visibility="{Binding IsTables, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE8C8;"/><TextBlock Text="{loc:Tr Ctx_CopyTable}"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding PasteCommand}" Style="{StaticResource ToolButton}"
                        Visibility="{Binding CanPaste, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE77F;"/><TextBlock Text="{loc:Tr Ctx_PasteTable}"/>
                    </StackPanel>
                </Button>
                <Border Width="1" Background="{StaticResource B.Border}" Margin="6,2"/>
                <Button Command="{Binding RefreshCommand}" Style="{StaticResource ToolButton}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Style="{StaticResource ToolIcon}" Text="&#xE72C;"/><TextBlock Text="{loc:Tr Btn_Refresh}"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="1" Margin="12,12,12,8" ItemsSource="{Binding Items}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                  AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  SelectionMode="Single" SelectionUnit="FullRow" HeadersVisibility="Column"
                  ClipboardCopyMode="None"
                  MouseDoubleClick="Grid_DoubleClick" KeyDown="Grid_KeyDown"
                  PreviewMouseRightButtonDown="Grid_RightClick">
            <DataGrid.ContextMenu>
                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem Header="{loc:Tr OL_OpenTable}" Command="{Binding OpenCommand}"/>
                    <MenuItem Header="{loc:Tr OL_DesignTable}" Command="{Binding DesignCommand}"
                              Visibility="{Binding CanDesign, Converter={StaticResource BoolToVis}}"/>
                    <Separator Visibility="{Binding IsTables, Converter={StaticResource BoolToVis}}"/>
                    <MenuItem Header="{loc:Tr Ctx_CopyTable}" Command="{Binding CopyCommand}"
                              Visibility="{Binding IsTables, Converter={StaticResource BoolToVis}}"/>
                    <MenuItem Header="{loc:Tr Ctx_PasteTable}" Command="{Binding PasteCommand}"
                              Visibility="{Binding CanPaste, Converter={StaticResource BoolToVis}}"/>
                    <Separator Visibility="{Binding CanDelete, Converter={StaticResource BoolToVis}}"/>
                    <MenuItem Header="{loc:Tr OL_DeleteTable}" Command="{Binding DeleteCommand}"
                              Visibility="{Binding CanDelete, Converter={StaticResource BoolToVis}}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="{loc:Tr Col_Name}" Width="2*" SortMemberPath="Name">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,0">
                                <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,7,0"
                                      Data="M2.5,3.5 H13.5 V12.5 H2.5 Z M2.5,6.5 H13.5 M2.5,9.5 H13.5 M6.17,3.5 V12.5 M9.83,3.5 V12.5"
                                      Stroke="#FF4C6275" StrokeThickness="1.2" Fill="Transparent" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{loc:Tr Col_Schema}" Binding="{Binding Schema}" Width="100"/>
                <DataGridTextColumn Header="{loc:Tr Col_Rows}" Binding="{Binding Rows, StringFormat=N0}" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right"/>
                            <Setter Property="Margin" Value="0,0,12,0"/>
                            <Setter Property="Foreground" Value="{StaticResource B.Numeric}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="{loc:Tr Col_Modified}" Width="180"
                                    Binding="{Binding Modified, StringFormat='yyyy-MM-dd HH:mm:ss'}"/>
                <DataGridTextColumn Header="{loc:Tr Col_Comment}" Width="*" Binding="{Binding Comment}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="2" Background="{StaticResource B.Sidebar}" Padding="14,6">
            <Grid>
                <TextBlock Text="{Binding Title}" Foreground="{StaticResource B.SidebarText}" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CountText}" Foreground="{StaticResource B.SidebarMuted}" FontSize="12"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
