<Window x:Class="DataPortStudio.Views.ErDiagramWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="ER Diagram" Height="680" Width="1100"
        WindowStartupLocation="CenterOwner"
        Background="#0d1117">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#161b22"
                BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="14,10">
            <Grid>
                <TextBlock x:Name="TitleLabel" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                           Foreground="#c9d1d9"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="RefreshButton" Content="↺  Reload" Click="Refresh_Click"
                            Background="#21262d" Foreground="#c9d1d9"
                            BorderBrush="#30363d" Padding="12,5"/>
                    <Button x:Name="RelayoutButton" Content="⊞  Re-layout" Margin="8,0,0,0" Click="Relayout_Click"
                            Background="#21262d" Foreground="#c9d1d9"
                            BorderBrush="#30363d" Padding="12,5"/>
                </StackPanel>
            </Grid>
        </Border>

        <wv2:WebView2 x:Name="WebView" Grid.Row="1"/>

        <Border Grid.Row="2" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,1,0,0" Padding="14,5">
            <TextBlock x:Name="StatusText" Foreground="#484f58" FontSize="11"
                       Text="Loading…" FontFamily="Consolas"/>
        </Border>
    </Grid>
</Window>
