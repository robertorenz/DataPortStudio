<Window x:Class="DataPortStudio.Views.SchemaDiffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Schema Diff" Height="640" Width="860"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource B.Bg}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource B.HeaderBar}"
                BorderBrush="{StaticResource B.Border}" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left DB -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Left database" FontSize="11" Foreground="{StaticResource B.TextMuted}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="LeftDbCombo" MinWidth="200" SelectionChanged="Combo_Changed"/>
                </StackPanel>

                <!-- Arrow -->
                <TextBlock Grid.Column="1" Text="↔" FontSize="20" VerticalAlignment="Bottom"
                           Foreground="{StaticResource B.TextMuted}" Margin="16,0,16,4"/>

                <!-- Right DB -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Right database" FontSize="11" Foreground="{StaticResource B.TextMuted}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="RightDbCombo" MinWidth="200" SelectionChanged="Combo_Changed"/>
                </StackPanel>

                <!-- Compare button -->
                <Button Grid.Column="3" x:Name="CompareButton" Content="Compare"
                        Style="{StaticResource AccentButton}"
                        Margin="20,0,0,0" VerticalAlignment="Bottom"
                        Click="Compare_Click" IsEnabled="False"/>
            </Grid>
        </Border>

        <!-- Results -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="ResultsPanel" Margin="16,12"/>
        </ScrollViewer>

        <!-- Status -->
        <Border Grid.Row="2" Background="{StaticResource B.Sidebar}" Padding="16,6">
            <TextBlock x:Name="StatusText" Foreground="{StaticResource B.SidebarText}" FontSize="12"
                       Text="Select two databases and click Compare."/>
        </Border>
    </Grid>
</Window>
