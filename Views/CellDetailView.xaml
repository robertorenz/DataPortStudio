<UserControl x:Class="DataPortStudio.Views.CellDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:beh="clr-namespace:DataPortStudio.Behaviors"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             xmlns:loc="clr-namespace:DataPortStudio.Services"
             Background="{StaticResource B.Surface}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{loc:Tr Detail_Cell}" Foreground="{StaticResource B.TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding DetailColumn}"
                           Margin="6,0,0,0" FontWeight="SemiBold" FontSize="12"
                           Foreground="{StaticResource B.Text}" VerticalAlignment="Center"/>
                <Border Margin="10,0,0,0" Padding="6,1" CornerRadius="3" Background="{StaticResource B.SurfaceAlt}"
                        BorderBrush="{StaticResource B.Border}" BorderThickness="1">
                    <TextBlock Text="{Binding ViewModeLabel}" FontSize="11" Foreground="{StaticResource B.TextMuted}"/>
                </Border>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="⤢" Width="26" Style="{StaticResource ToolButton}"
                        Command="{Binding PinDetailCommand}" ToolTip="{loc:Tr Tip_Pin}"/>
                <Button Style="{StaticResource PaneCloseButton}" Command="{Binding HideDetailPanelCommand}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <!-- Text -->
            <Border BorderBrush="{StaticResource B.Border}" BorderThickness="1" CornerRadius="6"
                    Visibility="{Binding IsTextMode, Converter={StaticResource BoolToVis}}">
                <TextBox Text="{Binding DetailText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" AcceptsTab="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         FontFamily="Consolas" FontSize="12" BorderThickness="0" Padding="8"/>
            </Border>
            <!-- Hex -->
            <Border BorderBrush="{StaticResource B.Border}" BorderThickness="1" CornerRadius="6"
                    Visibility="{Binding IsHexMode, Converter={StaticResource BoolToVis}}">
                <TextBox Text="{Binding DetailHex, Mode=OneWay}" IsReadOnly="True" TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                         VerticalContentAlignment="Top"
                         FontFamily="Consolas" FontSize="12" BorderThickness="0" Padding="8"/>
            </Border>
            <!-- Image -->
            <Border BorderBrush="{StaticResource B.Border}" BorderThickness="1" CornerRadius="6"
                    Background="{StaticResource B.SurfaceAlt}"
                    Visibility="{Binding IsImageMode, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Image Source="{Binding DetailImage}" Stretch="None"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="8"/>
                    </ScrollViewer>
                    <TextBlock Text="{loc:Tr Detail_NotImage}" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{StaticResource B.TextMuted}" FontSize="13"
                               Visibility="{Binding DetailImage, Converter={StaticResource NullToVis}}"/>
                </Grid>
            </Border>
            <!-- Web -->
            <Border BorderBrush="{StaticResource B.Border}" BorderThickness="1" CornerRadius="6" ClipToBounds="True"
                    Visibility="{Binding IsWebMode, Converter={StaticResource BoolToVis}}">
                <wv2:WebView2 beh:WebViewHtml.Html="{Binding DetailHtml}"/>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0"
                    Visibility="{Binding CanApplyDetail, Converter={StaticResource BoolToVis}}">
            <Button Content="{loc:Tr Detail_ApplyToCell}" Style="{StaticResource AccentButton}" Command="{Binding ApplyDetailCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
