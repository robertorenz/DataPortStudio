<Window x:Class="DataPortStudio.Views.RowIdentityDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" SizeToContent="Height"
        ShowInTaskbar="False" Width="460">
    <Border Background="{StaticResource B.Surface}" CornerRadius="12" Margin="16"
            BorderBrush="{StaticResource B.Border}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="4" Opacity="0.25" Color="#FF1F2933"/>
        </Border.Effect>
        <StackPanel>
            <Border Background="{StaticResource B.Sidebar}" CornerRadius="12,12,0,0" Padding="20,16"
                    MouseLeftButtonDown="Header_MouseDown">
                <TextBlock Text="Row identity" FontSize="16" FontWeight="SemiBold" Foreground="White"/>
            </Border>

            <StackPanel Margin="22,16,22,8">
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource B.TextMuted}" Margin="0,0,0,12"
                           Text="This table has no primary key. Choose the column(s) that uniquely identify a row — they're used in the WHERE clause when editing or deleting. Pick too few and an edit could match the wrong row."/>

                <CheckBox x:Name="UseAllCheck" Content="Use all columns (default, safest)"
                          Margin="0,0,0,10" Checked="UseAll_Changed" Unchecked="UseAll_Changed"/>

                <Border BorderBrush="{StaticResource B.Border}" BorderThickness="1" CornerRadius="6">
                    <ScrollViewer MaxHeight="280" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ColumnList" Margin="6">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Display}" IsChecked="{Binding IsChecked}"
                                              IsEnabled="{Binding Enabled}" Margin="4,3"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <Border Background="{StaticResource B.SurfaceAlt}" CornerRadius="0,0,12,12"
                    BorderBrush="{StaticResource B.Border}" BorderThickness="0,1,0,0" Padding="16,14">
                <Grid>
                    <Button Content="Detect" MinWidth="90" HorizontalAlignment="Left" Click="Detect_Click"
                            ToolTip="Suggest the smallest set of columns that are unique across the loaded rows"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" MinWidth="90" Margin="0,0,10,0" Click="Cancel_Click"/>
                        <Button Content="Apply" MinWidth="90" Style="{StaticResource AccentButton}"
                                Click="Apply_Click" IsDefault="True"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </Border>
</Window>
