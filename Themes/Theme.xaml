<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:avsearch="clr-namespace:ICSharpCode.AvalonEdit.Search;assembly=ICSharpCode.AvalonEdit">

    <!-- System color overrides so controls using SystemColors (e.g. SearchPanel arrows)
         match our light theme. In light mode these are mostly defaults, but we pin them
         explicitly so the SearchPanel looks right regardless of Windows system theme. -->
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}"   Color="#FF1F2933"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}"       Color="#FFF7F9FB"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}"        Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.WindowTextBrushKey}"    Color="#FF1F2933"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}"     Color="#FFD0E8FF"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FF1F2933"/>
    <SolidColorBrush x:Key="{x:Static SystemColors.GrayTextBrushKey}"      Color="#FF6B7A89"/>

    <!-- Full ControlTemplate override — avoids AvalonEdit's internal Path/SystemColor mess. -->
    <Style TargetType="{x:Type avsearch:SearchPanel}">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background"  Value="#FFF0F4F8"/>
        <Setter Property="Foreground"  Value="#FF1F2933"/>
        <Setter Property="FontFamily"  Value="Segoe UI"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type avsearch:SearchPanel}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="#FFD0D8E0" BorderThickness="1"
                            CornerRadius="6" Padding="6,4" Margin="0,4,4,0"
                            HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.15" Color="#000000"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <!-- Options dropdown -->
                            <ToggleButton x:Name="OptionsToggle"
                                          ToolTip="Search options" Padding="5,3" Margin="0,0,4,0"
                                          Cursor="Hand">
                                <TextBlock Text="▾" FontSize="11"/>
                            </ToggleButton>
                            <Popup IsOpen="{Binding IsChecked, ElementName=OptionsToggle}"
                                   StaysOpen="False" Placement="Bottom" AllowsTransparency="True">
                                <Border Background="White" BorderBrush="#FFD0D8E0" BorderThickness="1"
                                        CornerRadius="6" Padding="10,8" Margin="0,2,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.15" Color="#000000"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <CheckBox Content="Match case" Margin="0,2"
                                                  IsChecked="{Binding MatchCase, RelativeSource={RelativeSource AncestorType={x:Type avsearch:SearchPanel}}}"/>
                                        <CheckBox Content="Match whole words" Margin="0,2"
                                                  IsChecked="{Binding WholeWords, RelativeSource={RelativeSource AncestorType={x:Type avsearch:SearchPanel}}}"/>
                                        <CheckBox Content="Use regex" Margin="0,2"
                                                  IsChecked="{Binding UseRegex, RelativeSource={RelativeSource AncestorType={x:Type avsearch:SearchPanel}}}"/>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <!-- Search input -->
                            <TextBox x:Name="PART_searchTextBox"
                                     MinWidth="180" Margin="0,0,4,0" VerticalContentAlignment="Center"/>

                            <!-- Find Prev / Next -->
                            <Button Command="{x:Static avsearch:SearchCommands.FindPrevious}"
                                    ToolTip="Find Previous (Shift+F3)"
                                    Padding="7,3" Margin="0,0,2,0">◄</Button>
                            <Button Command="{x:Static avsearch:SearchCommands.FindNext}"
                                    ToolTip="Find Next (F3)"
                                    Padding="7,3" Margin="0,0,6,0">►</Button>

                            <!-- Close -->
                            <Button Command="{x:Static avsearch:SearchCommands.CloseSearchPanel}"
                                    ToolTip="Close (Esc)" Padding="7,3">✕</Button>

                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================ PALETTE ============================ -->
    <!-- Professional blue/slate. No purple. -->
    <Color x:Key="C.Bg">#FFEEF1F4</Color>
    <Color x:Key="C.Accent">#FF2D7FE0</Color>

    <SolidColorBrush x:Key="B.Bg"            Color="#FFEEF1F4"/>
    <SolidColorBrush x:Key="B.Surface"       Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="B.SurfaceAlt"    Color="#FFF7F9FB"/>
    <SolidColorBrush x:Key="B.HeaderBar"     Color="#FFFFFFFF"/>

    <SolidColorBrush x:Key="B.Sidebar"       Color="#FF1F2933"/>
    <SolidColorBrush x:Key="B.SidebarText"   Color="#FFCBD5DF"/>
    <SolidColorBrush x:Key="B.SidebarMuted"  Color="#FF8A99A8"/>
    <SolidColorBrush x:Key="B.SidebarHover"  Color="#FF2B3845"/>

    <SolidColorBrush x:Key="B.Border"        Color="#FFD9E0E6"/>
    <SolidColorBrush x:Key="B.BorderStrong"  Color="#FFC2CCD6"/>

    <SolidColorBrush x:Key="B.Text"          Color="#FF1F2933"/>
    <SolidColorBrush x:Key="B.TextMuted"     Color="#FF6B7A89"/>

    <SolidColorBrush x:Key="B.Accent"        Color="#FF2D7FE0"/>
    <SolidColorBrush x:Key="B.AccentHover"   Color="#FF3D8CEA"/>
    <SolidColorBrush x:Key="B.AccentPressed" Color="#FF2670CC"/>
    <SolidColorBrush x:Key="B.AccentText"    Color="#FFFFFFFF"/>

    <SolidColorBrush x:Key="B.Success"       Color="#FF2E9E5B"/>
    <SolidColorBrush x:Key="B.Danger"        Color="#FFD64545"/>
    <SolidColorBrush x:Key="B.DangerHover"   Color="#FFE05656"/>

    <SolidColorBrush x:Key="B.GridHeader"    Color="#FFF1F4F7"/>
    <SolidColorBrush x:Key="B.RowAlt"        Color="#FFF6F8FA"/>
    <SolidColorBrush x:Key="B.RowHover"      Color="#FFEAF2FB"/>
    <SolidColorBrush x:Key="B.RowSelected"   Color="#FFD6E7FA"/>
    <SolidColorBrush x:Key="B.GridLines"     Color="#FFE6EBF0"/>

    <!-- Icon glyph (Segoe Fluent / MDL2) used inside toolbar buttons. -->
    <Style x:Key="ToolIcon" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>

    <!-- ============================ TEXT ============================ -->
    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
    </Style>

    <!-- ============================ BUTTONS ============================ -->
    <!-- Neutral / secondary button (implicit). -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource B.Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B.BorderStrong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource B.SurfaceAlt}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource B.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary accent button. -->
    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{StaticResource B.Accent}"/>
        <Setter Property="Foreground" Value="{StaticResource B.AccentText}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B.Accent}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1" CornerRadius="6" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource B.AccentHover}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource B.AccentHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource B.AccentPressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger button. -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource AccentButton}">
        <Setter Property="Background" Value="{StaticResource B.Danger}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B.Danger}"/>
    </Style>

    <!-- Flat toolbar button: icon glyph + text, transparent. -->
    <Style x:Key="ToolButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FFE7EDF3"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Toggle button styled like a neutral toolbar button (used for Filter/Sort). -->
    <Style x:Key="ToolToggle" TargetType="ToggleButton">
        <Setter Property="Background" Value="{StaticResource B.Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B.BorderStrong}"/>
        <Setter Property="Padding" Value="12,7"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource B.SurfaceAlt}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource B.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource B.RowHover}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource B.Accent}"/>
                            <Setter Property="Foreground" Value="{StaticResource B.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Flat left-aligned button used as a dropdown menu item. -->
    <Style x:Key="MenuItemButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="5"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource B.RowHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===================== ADAPTIVE COMMAND BAR ===================== -->
    <!-- Toolbar button label: collapses to icon-only when the bar is compact
         AND the item is still inline (overflow-menu items keep their text). -->
    <Style x:Key="ToolLabel" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Style.Triggers>
            <MultiDataTrigger>
                <MultiDataTrigger.Conditions>
                    <Condition Binding="{Binding (ToolBar.IsOverflowItem), RelativeSource={RelativeSource AncestorType=ButtonBase}}" Value="False"/>
                    <Condition Binding="{Binding IsToolbarCompact}" Value="True"/>
                </MultiDataTrigger.Conditions>
                <Setter Property="Visibility" Value="Collapsed"/>
            </MultiDataTrigger>
        </Style.Triggers>
    </Style>

    <!-- The » overflow toggle shown when toolbar items don't fit. -->
    <Style x:Key="OverflowChevron" TargetType="ToggleButton">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="ToolTip" Value="More commands"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6"
                            Padding="8,7" Margin="4,0,0,0">
                        <TextBlock Text="»" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"
                                   Foreground="{StaticResource B.TextMuted}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FFE7EDF3"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource B.RowHover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Transparent command bar with native overflow (» menu). -->
    <Style x:Key="CommandBar" TargetType="ToolBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolBar">
                    <Grid>
                        <!-- DockPanel reserves the chevron's width on the right FIRST, so it
                             can never be squeezed off the edge by pinned items. -->
                        <DockPanel LastChildFill="True">
                            <ToggleButton x:Name="OverflowButton" DockPanel.Dock="Right" ClickMode="Press"
                                          Focusable="False" Style="{StaticResource OverflowChevron}"
                                          IsChecked="{Binding IsOverflowOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <ToolBarPanel x:Name="PART_ToolBarPanel" IsItemsHost="True"
                                          Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </DockPanel>
                        <Popup x:Name="OverflowPopup" Placement="Bottom" AllowsTransparency="True"
                               StaysOpen="False" Focusable="False"
                               PlacementTarget="{Binding ElementName=OverflowButton}"
                               IsOpen="{Binding IsOverflowOpen, RelativeSource={RelativeSource TemplatedParent}}">
                            <Border Background="{StaticResource B.Surface}" BorderBrush="{StaticResource B.Border}"
                                    BorderThickness="1" CornerRadius="8" Margin="0,4,8,8" Padding="4">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.2" Color="#FF1F2933"/>
                                </Border.Effect>
                                <ToolBarOverflowPanel x:Name="PART_ToolBarOverflowPanel" Margin="2"
                                                      WrapWidth="260" Focusable="True"
                                                      KeyboardNavigation.DirectionalNavigation="Cycle"/>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasOverflowItems" Value="False">
                            <Setter TargetName="OverflowButton" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Selectable engine card (icon + label) used in the connection dialog.
         Each card supplies its own Content (Path icon + TextBlock). -->
    <Style x:Key="EngineCard" TargetType="RadioButton">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="Foreground" Value="{StaticResource B.TextMuted}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Bd" Background="{StaticResource B.Surface}" CornerRadius="8"
                            BorderBrush="{StaticResource B.Border}" BorderThickness="1" Padding="6,10">
                        <ContentPresenter HorizontalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource B.SurfaceAlt}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource B.RowHover}"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource B.Accent}"/>
                            <Setter Property="Foreground" Value="{StaticResource B.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Navicat-style command-bar button: icon over a label. -->
    <Style x:Key="RibbonButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="MinWidth" Value="62"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="8,5" Margin="1,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FFE7EDF3"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource B.RowHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================ INPUTS ============================ -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource B.Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B.BorderStrong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="CaretBrush" Value="{StaticResource B.Accent}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource B.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource B.Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B.BorderStrong}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="CaretBrush" Value="{StaticResource B.Accent}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource B.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Margin" Value="0,0,18,0"/>
    </Style>

    <Style TargetType="Label">
        <Setter Property="Foreground" Value="{StaticResource B.TextMuted}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="0,0,0,3"/>
    </Style>

    <!-- ============================ TREEVIEW ============================ -->
    <!-- Expander chevron toggle. -->
    <Style x:Key="TreeChevron" TargetType="ToggleButton">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="Transparent" Width="16" Height="16">
                        <Path x:Name="Arrow" Data="M 4 2 L 8 6 L 4 10"
                              Stroke="{StaticResource B.SidebarMuted}" StrokeThickness="1.4"
                              StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              RenderTransformOrigin="0.5,0.5"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Arrow" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="90"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Arrow" Property="Stroke" Value="{StaticResource B.SidebarText}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TreeViewItem">
        <Setter Property="Foreground" Value="{StaticResource B.SidebarText}"/>
        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <StackPanel>
                        <Border x:Name="Bd" CornerRadius="5" Background="Transparent" Margin="0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ToggleButton x:Name="Expander" Grid.Column="0"
                                              Style="{StaticResource TreeChevron}"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press"/>
                                <ContentPresenter x:Name="Header" Grid.Column="1"
                                                  ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Stretch"/>
                            </Grid>
                        </Border>
                        <ItemsPresenter x:Name="ItemsHost" Margin="14,0,0,0"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource B.SidebarHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource B.Accent}"/>
                            <Setter Property="Foreground" Value="{StaticResource B.AccentText}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TreeView">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource B.SidebarText}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <!-- ============================ DATAGRID ============================ -->
    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource B.Surface}"/>
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="RowBackground" Value="{StaticResource B.Surface}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource B.RowAlt}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource B.GridLines}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource B.GridLines}"/>
        <Setter Property="GridLinesVisibility" Value="All"/>
        <Setter Property="RowHeaderWidth" Value="22"/>
        <Setter Property="RowHeight" Value="28"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="AutoGenerateColumns" Value="True"/>
        <Setter Property="CanUserResizeRows" Value="False"/>
        <Setter Property="EnableRowVirtualization" Value="True"/>
        <Setter Property="EnableColumnVirtualization" Value="True"/>
        <Setter Property="SelectionUnit" Value="CellOrRowHeader"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource B.GridHeader}"/>
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="BorderBrush" Value="{StaticResource B.GridLines}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>

    <Style TargetType="DataGridRowHeader">
        <Setter Property="Background" Value="{StaticResource B.GridHeader}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B.GridLines}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="13"/>
        <!-- Default cell template (sizes the in-place editor correctly); clip long values. -->
        <Setter Property="ClipToBounds" Value="True"/>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource B.RowSelected}"/>
                <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="{StaticResource B.Surface}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource B.RowHover}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===================== NAVICAT-STYLE CELLS ===================== -->
    <SolidColorBrush x:Key="B.Numeric"  Color="#FFA3322A"/>
    <SolidColorBrush x:Key="B.NullText" Color="#FF9AA7B4"/>

    <!-- Text cell: grays the "(Null)" placeholder. -->
    <Style x:Key="GridText" TargetType="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="8,0"/>
        <Style.Triggers>
            <Trigger Property="Text" Value="(Null)">
                <Setter Property="Foreground" Value="{StaticResource B.NullText}"/>
                <Setter Property="FontStyle" Value="Italic"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Numeric cell: right-aligned, maroon (Navicat). -->
    <Style x:Key="GridNumericText" TargetType="TextBlock" BasedOn="{StaticResource GridText}">
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Foreground" Value="{StaticResource B.Numeric}"/>
    </Style>

    <!-- Edit-in-place editor: blue border (Navicat EIP). -->
    <Style x:Key="GridEditBox" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
        <Setter Property="CaretBrush" Value="{StaticResource B.Accent}"/>
        <Setter Property="Padding" Value="6,1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="White" BorderBrush="{StaticResource B.Accent}"
                            BorderThickness="1.5" CornerRadius="2">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GridNumericEditBox" TargetType="TextBox" BasedOn="{StaticResource GridEditBox}">
        <Setter Property="HorizontalContentAlignment" Value="Right"/>
        <Setter Property="Foreground" Value="{StaticResource B.Numeric}"/>
    </Style>

    <!-- Drag handle used to resize a dockable pane. -->
    <Style x:Key="PaneThumb" TargetType="Thumb">
        <Setter Property="Height" Value="9"/>
        <Setter Property="Cursor" Value="SizeNS"/>
        <Setter Property="Margin" Value="16,0,16,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="Transparent">
                        <Border x:Name="Grip" Height="4" Width="52" CornerRadius="2"
                                Background="{StaticResource B.BorderStrong}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Grip" Property="Background" Value="{StaticResource B.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Clear close (✕) button for pane headers; reddens on hover. -->
    <Style x:Key="PaneCloseButton" TargetType="Button">
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="22"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="ToolTip" Value="Close"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                        <Path x:Name="X" Data="M0,0 L10,10 M10,0 L0,10" Width="10" Height="10"
                              Stroke="{StaticResource B.TextMuted}" StrokeThickness="1.5"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource B.Danger}"/>
                            <Setter TargetName="X" Property="Stroke" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Vertical drag handle to resize the side inspector panel. -->
    <Style x:Key="PaneThumbV" TargetType="Thumb">
        <Setter Property="Width" Value="9"/>
        <Setter Property="Cursor" Value="SizeWE"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="Transparent">
                        <Border x:Name="Grip" Width="4" Height="52" CornerRadius="2"
                                Background="{StaticResource B.BorderStrong}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Grip" Property="Background" Value="{StaticResource B.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Splitter handle used between the grid and the dockable panes. -->
    <Style x:Key="PaneSplitter" TargetType="GridSplitter">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridSplitter">
                    <Border Background="Transparent">
                        <Border Height="4" Width="48" CornerRadius="2"
                                Background="{StaticResource B.BorderStrong}"
                                HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================ TABS ============================ -->
    <Style x:Key="TabCloseButton" TargetType="Button">
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource B.TextMuted}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="9">
                        <TextBlock Text="✕" FontSize="10" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FFE2E8EE"/>
                            <Setter Property="Foreground" Value="{StaticResource B.Danger}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{StaticResource B.SurfaceAlt}"
                                BorderBrush="{StaticResource B.Border}" BorderThickness="0,0,0,1">
                            <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled">
                                <TabPanel IsItemsHost="True" Margin="8,4,8,0"/>
                            </ScrollViewer>
                        </Border>
                        <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{StaticResource B.TextMuted}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Margin" Value="0,0,2,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="6,6,0,0">
                        <Grid>
                            <Border x:Name="Accent" Height="2" VerticalAlignment="Top"
                                    Background="{StaticResource B.Accent}" Visibility="Collapsed"
                                    CornerRadius="2,2,0,0"/>
                            <ContentPresenter ContentSource="Header" Margin="14,9"
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource B.Bg}"/>
                            <Setter TargetName="Accent" Property="Visibility" Value="Visible"/>
                            <Setter Property="Foreground" Value="{StaticResource B.Text}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="False"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Bd" Property="Background" Value="#FFE7EDF3"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
